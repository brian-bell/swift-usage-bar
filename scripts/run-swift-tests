#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

swift build
swift test --enable-swift-testing

bin_path="$(swift build --show-bin-path)"
test_binary="$bin_path/AIUsageBarPackageTests.xctest/Contents/MacOS/AIUsageBarPackageTests"
if [ ! -f "$test_binary" ]; then
    printf 'expected SwiftPM test bundle binary was not built\n' >&2
    exit 1
fi

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

strings_output="$tmpdir/test-binary-strings"
strings "$test_binary" >"$strings_output"
if ! grep -q 'harnessWorks()' "$strings_output"; then
    printf 'expected Swift Testing harnessWorks() test to be linked into %s\n' "$test_binary" >&2
    exit 1
fi

cat >"$tmpdir/usage-core-smoke.swift" <<'SWIFT'
import Foundation
import UsageCore

if UsageCore.version != "0.1.0" {
    FileHandle.standardError.write(
        Data("expected UsageCore.version 0.1.0, got \(UsageCore.version)\n".utf8)
    )
    exit(1)
}
SWIFT

swiftc \
    -I "$bin_path/Modules" \
    "$bin_path/UsageCore.build/UsageCore.swift.o" \
    "$tmpdir/usage-core-smoke.swift" \
    -o "$tmpdir/usage-core-smoke"

"$tmpdir/usage-core-smoke"
