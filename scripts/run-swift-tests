#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

swift build

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT
test_log="$tmpdir/swift-test.log"

# On a CommandLineTools-only toolchain `swift test` compiles and links the
# suites but exits 0 without executing them (there is no test runner).
# Capture the output and require evidence that a test run actually happened.
swift test --enable-swift-testing 2>&1 | tee "$test_log"

if ! grep -qE 'Test run with [0-9]+ tests' "$test_log"; then
    printf 'swift test did not execute any tests (CommandLineTools-only toolchain?).\n' >&2
    printf 'Select full Xcode: sudo xcode-select -s /Applications/Xcode.app/Contents/Developer\n' >&2
    exit 1
fi
